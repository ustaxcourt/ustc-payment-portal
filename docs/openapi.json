  "paths": {
    "/init": {
      "post": {
        "summary": "Initialize a payment",
        "description": "Creates a new payment session with Pay.gov and returns a redirect URL for the user to complete payment.",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "sigv4": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitPaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment initialized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitPaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload (e.g., missing body, validation error)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestError"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - invalid SigV4 signature or client not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenError"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - a payment session is already initiated for this transaction reference ID",

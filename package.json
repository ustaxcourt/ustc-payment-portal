{
  "name": "@ustaxcourt/payment-portal",
  "version": "1.0.0",
  "description": "USTC Payment Portal client for Pay.gov integration",
  "main": "dist/index.js",
  "bin": {
    "ustc-payment-portal": "bin/ustc-payment-portal.js"
  },
  "engines": {
    "node": ">=24.12.0 <25.0.0"
  },
  "scripts": {
    "clean": "rimraf dist/*",
    "lint": "tslint -c tslint.json -p tsconfig.json",
    "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/devServer.ts --format cjs && node scripts/build-db.js",
    "build:lambda": "terraform/scripts/build-lambda.sh",
    "prepack": "npm-run-all clean build",
    "dev:start": "npm-run-all build start",
    "tsc": "tsc",
    "dev": "nodemon --delay 2 --watch src -e ts,ejs --exec npm run dev:start",
    "tf:build": "npm run build:lambda",
    "start": "node .",
    "test": "npx jest --config jest-unit.config.ts",
    "test:coverage": "npm run test -- --coverage",
    "test:integration:dev": "APP_ENV=local npx jest ./src/test/integration/ --testPathIgnorePatterns=sigv4Smoke.test.ts --testTimeout=30000",
    "test:integration": "npx jest ./src/test/integration/ --testPathIgnorePatterns=sigv4Smoke.test.ts --testTimeout=30000",
    "test:integration:sigv4": "BASE_URL=$BASE_URL npx jest ./src/test/integration/sigv4Smoke.test.ts --coverage --verbose",
    "test:db:setup": "node -r dotenv/config ./scripts/ensure-test-db.js && NODE_ENV=test APP_ENV=test npm run knex -- migrate:latest && NODE_ENV=test APP_ENV=test npm run knex -- seed:run",
    "ci:publish": "npm run build && changeset publish --provenance",
    "generate:openapi": "ts-node src/openapi/generate.ts",
    "start:dev-server": "node scripts/start-dev-server-runtime.js",
    "start:all": "node -r dotenv/config scripts/start-local-stack.js",
    "start:server:autokill": "AUTO_KILL_PORTS=true node -r dotenv/config scripts/start-local-stack.js",
    "start:portal": "START_PAY_GOV=false node -r dotenv/config scripts/start-local-stack.js",
    "start:pay-gov-test-server": "node scripts/start-pay-gov-test-server.js",
    "check:local-flow": "node -r dotenv/config scripts/check-local-flow.js",
    "knex": "node -r ts-node/register -r dotenv/config ./node_modules/knex/bin/cli.js",
    "migrate:make": "npm run knex -- migrate:make",
    "migrate:unlock": "npm run knex -- migrate:unlock",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:status": "npm run knex -- migrate:status",
    "migrate:list": "npm run knex -- migrate:list",
    "migrate:up": "npm run knex -- migrate:up $1",
    "migrate:down": "npm run knex -- migrate:down $1",
    "seed:make": "npm run knex -- seed:make $1",
    "seed:run": "npm run knex -- seed:run",
    "docker": "docker compose up",
    "docker:migration": "MIGRATION_MODE=1 docker compose up"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@faker-js/faker": "^10.3.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.28.0",
    "jest": "^30.1.3",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.10",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.3",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@aws-sdk/client-secrets-manager": "^3.901.0",
    "@aws-sdk/client-sts": "^3.1000.0",
    "@ustaxcourt/ustc-pay-gov-test-server": "^0.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5",
    "knex": "^3.1.0",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "objection": "^3.1.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "scripts/start-local-stack.js",
    "scripts/start-dev-server-runtime.js",
    "scripts/start-pay-gov-test-server.js",
    "scripts/lib/dbSetup.js",
    "scripts/lib/docker.js",
    "scripts/lib/log.js",
    "scripts/lib/parsePort.js",
    "scripts/lib/ports.js",
    "docker-compose.consumer.yml",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ustaxcourt/ustc-payment-portal.git"
  },
  "publishConfig": {
    "access": "public"
  }
}

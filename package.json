{
  "name": "@ustaxcourt/payment-portal",
  "version": "0.1.3",
  "description": "USTC Payment Portal client for Pay.gov integration",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.12.0 <25.0.0"
  },
  "scripts": {
    "clean": "rimraf dist/*",
    "lint": "tslint -c tslint.json -p tsconfig.json",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "build:lambda": "terraform/scripts/build-lambda.sh",
    "dev:start": "npm-run-all build start",
    "tsc": "tsc",
    "dev": "nodemon --delay 2 --watch src -e ts,ejs --exec npm run dev:start",
    "tf:build": "npm run build:lambda",
    "start": "node .",
    "test": "npx jest --config jest-unit.config.ts",
    "test:coverage": "npm run test -- --coverage",
    "test:integration:dev": "NODE_ENV=local DOTENV_CONFIG_PATH=.env.dev npx jest ./src/test/integration/",
    "test:integration": "npx jest ./src/test/integration/",
    "test:db:setup": "NODE_ENV=test npm run knex -- migrate:latest && NODE_ENV=test npm run knex -- seed:run",
    "dashboard:test": "npm run test:db:setup && npm run --prefix dashboard-api test",
    "dashboard:test:coverage": "npm run test:db:setup && npm run --prefix dashboard-api test:coverage",
    "web-client:test": "npm run --prefix web-client test:e2e",
    "web-client:test:coverage": "npm run --prefix web-client test:coverage",
    "ci:publish": "npm run build && changeset publish --provenance",
    "generate:openapi": "ts-node src/openapi/generate.ts",
    "knex": "node -r ts-node/register -r dotenv/config ./node_modules/knex/bin/cli.js",
    "migrate:make": "npm run knex -- migrate:make $1",
    "migrate:unlock": "npm run knex -- migrate:unlock",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:status": "npm run knex -- migrate:status",
    "migrate:list": "npm run knex -- migrate:list",
    "migrate:up": "npm run knex -- migrate:up $1",
    "migrate:down": "npm run knex -- migrate:down $1",
    "seed:make": "npm run knex -- seed:make $1",
    "seed:run": "npm run knex -- seed:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@faker-js/faker": "^10.3.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/axios": "^0.14.4",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/node-fetch": "^2.6.13",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.25.10",
    "express": "^5.1.0",
    "jest": "^30.1.3",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.3",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "uuid": "^13.0.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@aws-sdk/client-secrets-manager": "^3.901.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.2.5",
    "joi": "^18.0.2",
    "knex": "^3.1.0",
    "node-fetch": "^3.3.2",
    "objection": "^3.1.5",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ustaxcourt/ustc-payment-portal.git"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@ustaxcourt/payment-portal",
  "version": "1.0.1",
  "description": "USTC Payment Portal client for Pay.gov integration",
  "main": "dist/index.js",
  "bin": {
    "payment-portal": "bin/ustc-payment-portal.js"
  },
  "engines": {
    "node": ">=24.12.0 <25.0.0"
  },
  "scripts": {
    "clean": "rimraf dist/*",
    "lint": "biome lint .",
    "lint:ci": "biome lint --reporter=github .",
    "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/devServer.ts --format cjs",
    "build:lambda": "terraform/scripts/build-lambda.sh",
    "prepack": "npm-run-all clean build",
    "dev:start": "npm-run-all build start",
    "tsc": "tsc",
    "dev": "nodemon --delay 2 --watch src -e ts,ejs --exec npm run dev:start",
    "tf:build": "npm run build:lambda",
    "tf:test": "bash terraform/scripts/run-module-tests.sh",
    "start": "node -r dotenv/config .",
    "test": "npx jest --config jest-unit.config.ts",
    "test:coverage": "npm run test -- --coverage",
    "test:integration:dev": "APP_ENV=local npx jest ./src/test/integration/ --testPathIgnorePatterns=sigv4Smoke.test.ts --testPathIgnorePatterns=deployHealthSmoke.test.ts --testPathIgnorePatterns=/dist/ --testTimeout=30000",
    "test:integration": "npx jest ./src/test/integration/ --testPathIgnorePatterns=sigv4Smoke.test.ts --testPathIgnorePatterns=deployHealthSmoke.test.ts --testTimeout=30000",
    "test:integration:sigv4": "BASE_URL=$BASE_URL npx jest ./src/test/integration/sigv4Smoke.test.ts --coverage --verbose",
    "test:staging-e2e": "playwright test --config src/test/staging-e2e/playwright.config.ts",
    "test:staging-e2e:report": "playwright show-report src/test/staging-e2e/playwright-report",
    "test:deploy-health": "BASE_URL=$BASE_URL npx jest ./src/test/integration/deployHealthSmoke.test.ts --verbose",
    "test:db:setup": "node -r dotenv/config ./scripts/ensure-test-db.js && NODE_ENV=test APP_ENV=test npm run knex -- migrate:latest && NODE_ENV=test APP_ENV=test npm run knex -- seed:run",
    "test:types": "tsc --project tsconfig.test-types.json",
    "ci:publish": "npm run build && changeset publish",
    "generate:openapi": "ts-node src/openapi/generate.ts",
    "start:dev-server": "node scripts/start-dev-server-runtime.js",
    "start:all": "node -r dotenv/config scripts/start-local-stack.js",
    "start:server:autokill": "AUTO_KILL_PORTS=true node -r dotenv/config scripts/start-local-stack.js",
    "start:portal": "START_PAY_GOV=false node -r dotenv/config scripts/start-local-stack.js",
    "start:pay-gov-test-server": "node scripts/start-pay-gov-test-server.js",
    "check:local-flow": "node -r dotenv/config scripts/check-local-flow.js",
    "knex": "node -r tsconfig-paths/register -r ts-node/register -r dotenv/config ./node_modules/knex/bin/cli.js",
    "migrate:make": "npm run knex -- migrate:make",
    "migrate:unlock": "npm run knex -- migrate:unlock",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:status": "npm run knex -- migrate:status",
    "migrate:list": "npm run knex -- migrate:list",
    "migrate:up": "npm run knex -- migrate:up $1",
    "migrate:down": "npm run knex -- migrate:down $1",
    "seed:make": "npm run knex -- seed:make $1",
    "seed:run": "npm run knex -- seed:run",
    "docker": "docker compose up",
    "docker:migration": "MIGRATION_MODE=1 docker compose up",
    "test:performance:stress:full": "scripts/run-performance-test.sh stress full",
    "test:performance:stress:init": "scripts/run-performance-test.sh stress init",
    "test:performance:load:full": "scripts/run-performance-test.sh load full",
    "test:performance:load:init": "scripts/run-performance-test.sh load init"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@smithy/core": "^3.29.4",
    "@smithy/signature-v4": "^5.5.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.3",
    "@types/node-fetch": "^2.6.13",
    "@types/swagger-ui-express": "^4.1.8",
    "artillery": "^2.0.33",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.0.0",
    "@aws-sdk/client-secrets-manager": "^3.1093.0",
    "@aws-sdk/client-ssm": "^3.1093.0",
    "@aws-sdk/client-sts": "^3.1093.0",
    "@ustaxcourt/ustc-pay-gov-test-server": "^0.2.4",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "knex": "^3.3.0",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "objection": "^3.1.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "db",
    "dist",
    "scripts/start-local-stack.js",
    "scripts/start-dev-server-runtime.js",
    "scripts/start-pay-gov-test-server.js",
    "scripts/lib/dbSetup.js",
    "scripts/lib/docker.js",
    "scripts/lib/log.js",
    "scripts/lib/parsePort.js",
    "scripts/lib/ports.js",
    "scripts/lib/wireChild.js",
    "docker-compose.consumer.yml",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ustaxcourt/ustc-payment-portal.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "read-yaml-file": "^2.1.0",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    },
    "tsup": {
      "esbuild": "^0.28.1"
    }
  }
}

{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"noExcessiveCognitiveComplexity": "warn"
			},
			"suspicious": {
				"noConsole": "error"
			},
			"nursery": {
				"noFloatingPromises": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["scripts/**", "bin/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		}
	],
	"formatter": {
		"enabled": true
	},
	"files": {
		"includes": [
			"**",
			"!docs/openapi.json",
			"!docs/openapi.yaml",
			"!src/health/emf.ts"
		]
	}
}
